// Secrets.example.xcconfig
// =============================================================================
// TEMPLATE — safe to commit. Copy this file to "Secrets.xcconfig" (same folder)
// and fill in the real values. Secrets.xcconfig is git-ignored.
//
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//
// Values come from: Supabase → Project Settings → API
// =============================================================================

SUPABASE_HOST = YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY = YOUR-ANON-PUBLIC-KEY

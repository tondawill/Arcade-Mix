{
  "sourceLanguage": "en",
  "strings": {
    "Auth_SignIn": {
      "comment": "Account menu item shown to a guest: go to the sign-in screen.",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlásit se"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign In"
          }
        }
      }
    },
    "Login_Guest": {
      "comment": "Button: enter the app without signing in (works offline).",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokračovat bez přihlášení"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue without signing in"
          }
        }
      }
    },
    "Login_Guest_Note": {

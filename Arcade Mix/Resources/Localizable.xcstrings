    "AFL_HowTo_Rule_Score" : {
      "comment" : "AFL rule.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Švihni rovně nahoru pro gól (6); mimo střed je behind (1)."

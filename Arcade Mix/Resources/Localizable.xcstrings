    "AFL_HowTo_Control_Pass" : {
      "comment" : "AFL control.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepni na spoluhráče nebo na Přihrávku pro ruční přihrávku."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap a teammate or the Pass button to handpass."
          }

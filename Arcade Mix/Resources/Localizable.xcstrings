    "AFL_HowTo_Control_Move" : {
      "comment" : "AFL control.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Táhni kdekoli pro pohyb (nebo WASD / šipky)."

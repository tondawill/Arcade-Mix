    "AFL_HowTo_Rule_Mark" : {
      "comment" : "AFL rule.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chyť nakopnutý míč ze vzduchu pro mark."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catch the kick-in on the full to take a mark."
